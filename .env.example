# Copy this file to .env and fill in real values there. Never commit .env or paste its
# contents into chat — treat every value below like a password.

PORT=3000
# Must match the redirect URI registered with each provider's OAuth app, e.g. http://localhost:3000
BASE_URL=http://localhost:3000

# Signs the login session cookie. Any long random string. Required for anything beyond
# quick local testing (a default is used if unset, with a warning logged).
SESSION_SECRET=

# The account email that sees the Admin panel (an "Admin" badge, usage stats, the default
# model picker, and the site announcement banner). Must match exactly what the account signs
# in with — a Google profile email, or the email used to sign up.
ADMIN_EMAIL=

# Encrypts data/connections.json (OAuth access/refresh tokens) at rest. Any long random
# string. Required for anything beyond quick local testing (a default is used if unset,
# with a warning logged).
ENCRYPTION_KEY=

# Email verification + password reset, sent via Resend (resend.com, free tier). Get a key
# at resend.com/api-keys. Without a verified sending domain, Resend's shared test sender
# (onboarding@resend.dev) only delivers to your own Resend account email — verify a domain
# in the Resend dashboard once you have one, then set EMAIL_FROM to an address on it.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Chat runs on Ollama only. Leave both blank to use a local install (http://localhost:11434, no key).
# Set OLLAMA_API_KEY for Ollama Cloud/"Turbo" hosted models instead — this alone switches
# the default endpoint to https://ollama.com. Set OLLAMA_BASE_URL too if it's hosted elsewhere.
#
# NOTE: OLLAMA_API_KEY is now ALSO required for the "Web search" composer toggle below,
# even if you want your chat model to keep running locally. If that's you, set
# OLLAMA_API_KEY (for search) AND explicitly set OLLAMA_BASE_URL=http://localhost:11434
# (to keep chat local) — otherwise setting the key alone will switch chat to the cloud too.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=

# Deep search (composer toggle) — real web search via Ollama's own web search API
# (https://ollama.com/api/web_search). Free Ollama account required — get a key at
# https://ollama.com/settings/keys. Uses OLLAMA_API_KEY above, no separate key needed.

# Flights — automatically detected from your message (e.g. "flights from LON to NYC on
# 2026-08-01"), no toggle needed. Real search via Kiwi.com's Tequila API. Free self-serve
# signup, no partner approval needed: https://tequila.kiwi.com/portal/login
KIWI_API_KEY=

# Hotels — automatically detected from your message (e.g. "hotels in PAR from 2026-08-01
# to 2026-08-03"), no toggle needed. Real search via Amadeus for Developers' self-service
# Hotel API. Free self-serve signup, no partner approval needed (this uses their "test"
# environment: real API shape, but a sample dataset rather than full production inventory):
# https://developers.amadeus.com/register
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Google is used TWICE: sign-in (below) needs its own redirect URI in addition to the
# Connections one — see README. Same client ID/secret works for both.
#
# App connections (only fill in the ones you want to enable — each requires you to
# register an OAuth app with that provider first; see README for redirect URI setup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Canvas is self-hosted per institution (e.g. https://yourschool.instructure.com) — set your
# institution's base URL here in addition to the client ID/secret.
CANVAS_BASE_URL=
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=

# TripIt aggregates a user's flights, hotels, and Airbnb bookings into one connection.
# Unlike every other provider above, TripIt uses OAuth 1.0a, not OAuth 2.0 — register an app
# at tripit.com/developer to get these (self-serve, no partner approval needed).
TRIPIT_CONSUMER_KEY=
TRIPIT_CONSUMER_SECRET=

# Airport transfers — automatically detected from your message when it contains the word
# "transfer" (e.g. "book a transfer from CDG to Paris on 2026-08-01"), no toggle needed.
# Reuses the same AMADEUS_CLIENT_ID/SECRET above (test/sample dataset, same as hotels) —
# no separate signup needed if you've already set those.

# Weather and currency conversion — automatically detected from your message (e.g. "weather
# in Tokyo on 2026-08-01", "convert 100 USD to EUR"), no toggle needed and no API keys at
# all: both run on fully free, keyless services (Open-Meteo and open.er-api.com).
